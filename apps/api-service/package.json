{
  "name": "@classroom/api-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./routers": "./src/router/index.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --packages=external",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "clean": "rm -rf dist .turbo .tsbuildinfo"
  },
  "dependencies": {
    "@bull-board/api": "8.0.1",
    "@bull-board/hono": "8.0.1",
    "@orpc/server": "1.14.6",
    "@t3-oss/env-core": "0.13.11",
    "bullmq": "5.79.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.6.15",
    "ioredis": "5.10.1",
    "pino": "10.3.1",
    "postgres": "3.4.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.2.2",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.0.0",
    "typescript": "5.7.3"
  }
}
