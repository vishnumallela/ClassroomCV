{
  "name": "classroom-surveillance",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/bun": "1.2.2",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "turbo": "2.3.4",
    "typescript": "5.7.3"
  },
  "overrides": {
    "ioredis": "5.10.1"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.14"
}
