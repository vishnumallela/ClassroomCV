# Production GPU profile for the Luminary ML service.
# Copy to services/ml-service/.env on the NVIDIA host (and install a CUDA torch
# build: pip/uv install torch with the matching CUDA wheel).

DATABASE_URL=postgres://postgres:postgres@localhost:5433/classroom

# Best-accuracy pose model. YOLO26 is NMS-free and reports up to +7.2 pose AP
# over YOLO11 (COCO m-pose 68.8, l-pose 70.4). The x variant is affordable on a
# real GPU. For a large LIVE fleet (many concurrent streams) prefer
# yolo26l-pose for a better throughput/accuracy balance.
MODEL_NAME=yolo26x-pose.pt
DEVICE=cuda
# A GPU has the headroom to feed the detector closer to native resolution,
# which is the single biggest lever for tiny back-row students.
IMGSZ=1536

# --- TensorRT (recommended for production): ~5x fp16 speedup ------------------
# One-time export on the GPU host, then point MODEL_NAME at the engine:
#   yolo export model=yolo26x-pose.pt format=engine half=True dynamic=True imgsz=1536
#   MODEL_NAME=yolo26x-pose.engine
# Ultralytics loads a .engine transparently; no code change is needed.
